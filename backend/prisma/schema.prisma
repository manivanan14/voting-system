generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id      Int    @id @default(autoincrement())
  name    String
  photo   String
  symbol  String
  votes   Vote[]
}

model Vote {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  voterIp     String    @unique
  createdAt   DateTime  @default(now())
}
